:root{--primary:#0b1f3a;--accent:#2563eb;--bg:#f5f7fb;--card:#fff;--text:#111827;--muted:#6b7280;--danger:#dc2626;--success:#16a34a}*{box-sizing:border-box}body{margin:0;background:var(--bg);font-family:Arial,Helvetica,sans-serif;color:var(--text)}.wrap{max-width:1100px;margin:0 auto;padding:24px}.hero{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#0b1f3a,#1d4ed8)}.card{background:var(--card);border-radius:18px;box-shadow:0 15px 40px #0002;padding:24px}.hero .card{width:min(520px,92vw);text-align:center}.title{font-size:34px;margin:0 0 8px;color:var(--primary)}.subtitle{color:var(--muted);margin:0 0 22px}.grid{display:grid;gap:16px}.grid2{grid-template-columns:repeat(2,minmax(0,1fr))}.grid3{grid-template-columns:repeat(3,minmax(0,1fr))}input,select,textarea{width:100%;padding:12px 14px;border:1px solid #d1d5db;border-radius:12px;font-size:15px;background:white}textarea{min-height:90px}.btn{border:0;border-radius:12px;padding:12px 16px;font-weight:700;cursor:pointer;background:var(--accent);color:white}.btn.secondary{background:#e5e7eb;color:#111827}.btn.danger{background:var(--danger)}.btn.success{background:var(--success)}.btn:disabled{opacity:.6;cursor:not-allowed}.topbar{background:var(--primary);color:white;padding:16px 24px;display:flex;justify-content:space-between;align-items:center;gap:12px}.pill{background:#eef2ff;color:#1d4ed8;border-radius:999px;padding:8px 12px;font-weight:700;display:inline-block}.question{border:1px solid #e5e7eb;border-radius:16px;padding:18px;margin:16px 0;background:white}.options{display:grid;gap:10px;margin-top:12px}.option{border:1px solid #d1d5db;border-radius:12px;padding:12px;text-align:left;background:#fff;cursor:pointer}.option.active{border-color:#2563eb;background:#eff6ff}.table{width:100%;border-collapse:collapse;background:white;border-radius:16px;overflow:hidden}.table th,.table td{padding:12px;border-bottom:1px solid #e5e7eb;text-align:left}.table th{background:#f3f4f6}.muted{color:var(--muted)}.row{display:flex;gap:10px;flex-wrap:wrap;align-items:center}.spacer{height:18px}.admin-layout{display:grid;grid-template-columns:1fr 1fr;gap:18px}.small{font-size:13px}.center{text-align:center}@media(max-width:800px){.grid2,.grid3,.admin-layout{grid-template-columns:1fr}.title{font-size:28px}.wrap{padding:16px}.topbar{flex-direction:column;align-items:flex-start}}
